{
  "name": "ecommerce-system-nodejs",
  "version": "1.0.0",
  "description": "Complete E-Commerce System with Role-Based Permissions - Node.js Implementation",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "migrate": "node src/database/migrations/run.js",
    "setup:bucket": "node scripts/create-supabase-bucket.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/ecommerce-system.exe",
    "build:win32": "pkg . --targets node18-win-x86 --output dist/ecommerce-system-32bit.exe",
    "build:all": "pkg . --targets node18-win-x64,node18-win-x86 --output-path dist/",
    "package": "npm run build:win"
  },
  "keywords": [
    "ecommerce",
    "nodejs",
    "express",
    "mongodb",
    "mysql",
    "jwt",
    "rbac"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.6",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "mongodb": "^6.3.0",
    "mongoose": "^9.0.2",
    "mongoose-update-if-current": "^1.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "stripe": "^14.7.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js",
      "scripts/**/*.js"
    ],
    "assets": [
      "logs/**/*",
      ".env.example"
    ],
    "outputPath": "dist"
  }
}
